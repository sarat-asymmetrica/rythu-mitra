/*
 * SpacetimeDB TypeScript module config for Rythu Mitra.
 * Some options are required by SpacetimeDB — do not modify those.
 */
{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* Required by SpacetimeDB — do not modify */
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["./**/*"]
}
