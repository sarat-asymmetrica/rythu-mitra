{
  "name": "rythu-mitra-module",
  "version": "1.0.0",
  "description": "Rythu Mitra — vernacular-first farmer business management (SpacetimeDB module)",
  "scripts": {
    "build": "spacetime build",
    "publish": "spacetime publish rythu-mitra",
    "publish:clear": "spacetime publish rythu-mitra --clear-database -y",
